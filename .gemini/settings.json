{
  "approvalMode": "yolo",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/zsh -l -c \"aigon check-version --json\"",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "/bin/zsh -l -c \"aigon project-context --json\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/zsh -l -c \"aigon check-agent-signal --json\"",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "/bin/zsh -l -c \"aigon capture-gemini-telemetry\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}