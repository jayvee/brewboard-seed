{
  "permissions": {
    "allow": [
      "Bash(aigon:*)",
      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npx *)",
      "Bash(pnpm install*)",
      "Bash(pnpm run *)",
      "Bash(pnpm *)",
      "Bash(yarn install*)",
      "Bash(yarn *)",
      "Bash(bun install*)",
      "Bash(bun run *)",
      "Bash(node *)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git push*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git stash*)",
      "Bash(git rebase*)",
      "Bash(git merge*)",
      "Bash(curl *)",
      "Bash(cat *)",
      "Bash(ls*)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Read(/Users/jviner/.aigon/worktrees/brewboard/feature-01-cc-format-date/**)",
      "Edit(/Users/jviner/.aigon/worktrees/brewboard/feature-01-cc-format-date/**)",
      "Write(/Users/jviner/.aigon/worktrees/brewboard/feature-01-cc-format-date/**)",
      "Bash(cd /Users/jviner/.aigon/worktrees/brewboard/feature-01-cc-format-date:*)",
      "Bash(git -C /Users/jviner/.aigon/worktrees/brewboard/feature-01-cc-format-date:*)",
      "Bash(node:*)",
      "Bash(npm:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo:*)",
      "Bash(su:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/zsh -l -c \"aigon check-version --notice-only\"",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "/bin/zsh -l -c \"aigon project-context\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/zsh -l -c \"aigon capture-session-telemetry\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/zsh -l -c \"aigon check-agent-submitted\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}